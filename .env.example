# Environment Variables for Stadium OS v1.0
# Copy this file to .env.local and fill in your values.

# Server-side Supabase Admin Client (bypasses RLS)
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_secret

# Google Gemini AI API Key
GEMINI_API_KEY=your_gemini_api_key

# Internal Worker Authentication Secret
INTERNAL_WORKER_SECRET=formulate_a_secure_token_key

# Client-side Supabase Public Client (used for real-time subscriptions)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
